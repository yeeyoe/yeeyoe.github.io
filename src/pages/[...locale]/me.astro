---
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  type LocaleKey,
} from "@/i18n/config";
import AboutLayout from "@/layouts/AboutLayout.astro";
import { getMeForLocale } from "@/utils/about";
import { render } from "astro:content";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map(locale => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }));
}

const { locale = DEFAULT_LOCALE } = Astro.params;
const me = await getMeForLocale(locale as LocaleKey);

let Content;

let frontmatter: { title: string; description?: string } = {
  title: "",
};

if (me) {
  const rendered = await render(me);
  Content = rendered.Content;

  frontmatter = {
    title: me.data.title,
    description: me.data.description,
  };
}
---

<AboutLayout frontmatter={frontmatter}>
  {Content ? <Content /> : <p />}
</AboutLayout>

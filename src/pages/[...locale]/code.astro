---
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  type LocaleKey,
} from "@/i18n/config";
import PageLayout from "@/layouts/PageLayout.astro";
import { getCodeForLocale } from "@/utils/about";
import { render } from "astro:content";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map(locale => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }));
}

const { locale = DEFAULT_LOCALE } = Astro.params;
const code = await getCodeForLocale(locale as LocaleKey);

let Content;

let frontmatter: { title: string; description?: string } = {
  title: "",
};

if (code) {
  const rendered = await render(code);
  Content = rendered.Content;

  frontmatter = {
    title: code.data.title,
    description: code.data.description,
  };
}
---

<PageLayout frontmatter={frontmatter} pageTitleKey="code">
  {Content ? <Content /> : <p />}
</PageLayout>

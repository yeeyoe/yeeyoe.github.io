---
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  type LocaleKey,
} from "@/i18n/config";
import PageLayout from "@/layouts/PageLayout.astro";
import { getTeachForLocale } from "@/utils/about";
import { render } from "astro:content";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map(locale => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }));
}

const { locale = DEFAULT_LOCALE } = Astro.params;
const teach = await getTeachForLocale(locale as LocaleKey);

let Content;

let frontmatter: { title: string; description?: string } = {
  title: "",
};

if (teach) {
  const rendered = await render(teach);
  Content = rendered.Content;

  frontmatter = {
    title: teach.data.title,
    description: teach.data.description,
  };
}
---

<PageLayout frontmatter={frontmatter} pageTitleKey="teach">
  {Content ? <Content /> : <p />}
</PageLayout>
